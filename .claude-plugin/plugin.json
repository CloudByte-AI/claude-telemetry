{
  "name": "claude-telemetry",
  "version": "0.1.8",
  "description": "Claude Telemetry - Observability stack for claude - Prompt, Observability, Tokens.",
  "author": {
    "name": "CloudByte-AI"
  },
  "hooks": {
    "Setup": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/validate.sh"
      }
    ]
  },
  "mcpServers": {
    "cloudbyte": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "src.mcp.server"
      ],
      "alwaysLoad": true
    }
  }
}
{
  "name": "claude-telemetry",
  "version": "0.1.9",
  "description": "Claude Telemetry - Observability stack for claude - Prompt, Observability, Tokens.",
  "author": {
    "name": "CloudByte-AI"
  },
  "hooks": {
    "Setup": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/validate.sh\"",
            "timeout": 600
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "cloudbyte": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "src.mcp.server"
      ],
      "alwaysLoad": true
    }
  }
}
{
  "name": "claude-telemetry",
  "description": "Claude Telemetry - Observablity stack for claude - Prompt, Observablity, Tokens.",
  "version": "0.1.2",
  "author": {
    "name": "CloudByte-AI"
  },
    "mcpServers": {
    "cloudbyte": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "src.mcp.server"
      ],
      "alwaysLoad": true
    }
  }
}

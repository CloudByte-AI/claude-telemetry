{
  "name": "claude-telemetry",
  "version": "0.1.7",
  "description": "Claude Telemetry - Observability stack for claude - Prompt, Observability, Tokens.",
  "author": {
    "name": "CloudByte-AI"
  },
  "hooks": {
    "setup": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/validate.sh"]
    }
  },
  "mcpServers": {
    "cloudbyte": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "src.mcp.server"
      ],
      "alwaysLoad": true
    }
  }
}
{
  "name": "claude-telemetry",
  "version": "0.1.25",
  "description": "Claude Telemetry - Observability stack for claude - Prompt, Observability, Tokens.",
  "author": {
    "name": "CloudByte-AI"
  },
  "mcpServers": {
    "cloudbyte": {
      "command": "uv",
      "args": [
        "run",
        "--python",
        "3.12",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "src.mcp.server"
      ],
      "alwaysLoad": true
    }
  }
}
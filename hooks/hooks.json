{
  "description": "CloudByte Unified Memory & Sync System",
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/validate.sh\"",
            "timeout": 600
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"${CLAUDE_PLUGIN_ROOT}\" -m src.main session_start",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"${CLAUDE_PLUGIN_ROOT}\" -m src.main user_prompt",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"${CLAUDE_PLUGIN_ROOT}\" -m src.main stop",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"${CLAUDE_PLUGIN_ROOT}\" -m src.main session_end",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
